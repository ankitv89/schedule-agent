# Database string (local sqlite)
DATABASE_URL="file:./dev.db"

# Master API Key to protect the Chat API Endpoint
APP_API_KEY="my-secret-key-12345"

# Google AI Studio or Vertex AI Gemini Key
GOOGLE_API_KEY="your-gemini-key-here"

# Google Calendar OAuth2 Configuration for Schedule Agent
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REFRESH_TOKEN="your-refresh-token"

{
  "openapi": "3.0.0",
  "info": {
    "title": "Schedule Agent API",
    "version": "1.0.0",
    "description": "Multi-agent LangGraph system powered by MCP to coordinate Google Calendar, tasks, and notes."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Server (Local or Cloud Run)"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/chat": {
      "post": {
        "summary": "Send a message to the agent orchestrator",
        "description": "Interacts with the AI agent. The agent will process user intent and utilize MCP tools such as Calendar and Prisma DB.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Can you list my events for today?"
                  },
                  "sessionId": {
                    "type": "string",
                    "example": "session-xyz789"
                  },
                  "refreshToken": {
                    "type": "string",
                    "example": "1//0abcdefg12345"
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful agent response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid x-api-key header."
          },
          "500": {
            "description": "Server error processing the AI response."
          }
        }
      }
    }
  }
}
